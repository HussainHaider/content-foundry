# LLM — OpenAI is primary; Anthropic is automatic fallback (rate limit / outage)
# At least one key is required. Both set = full fallback protection.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings for RAG (get key at voyageai.com — voyage-3 = 1024 dims)
VOYAGE_API_KEY=pa-...

# Web search (get free key at serper.dev — 2500 searches/month free)
SERPER_API_KEY=...

# Vector DB (local Docker URL, change for cloud Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=""

# Publishing — optional, app works without these
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=...
BUFFER_TOKEN=...
BUFFER_PROFILE_IDS=profile_id_1,profile_id_2

# Observability — optional but recommended (langsmith.com)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=content-marketing-engine

# ── Storyblok publishing (FastAPI service only — token never reaches Streamlit) ──
# Management API write token (Personal Access Token with write scope). Used by the
# FastAPI service to create stories. Rotate in the Storyblok UI; never commit.
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_SPACE_ID=
# Region selects the Management API host: eu (default), us, ap, ca, cn
STORYBLOK_REGION=eu
# Optional: parent folder story id to nest blog stories under (e.g. /blog)
STORYBLOK_BLOG_PARENT_ID=

# Internal auth between the Streamlit app and the FastAPI publishing service.
# Generate a random secret; set the SAME value in both processes.
PUBLISHER_API_KEY=
# Base URL of the FastAPI service as seen by Streamlit.
# Local: http://localhost:8000 — docker compose: http://api:8000
PUBLISHER_API_URL=http://localhost:8000
